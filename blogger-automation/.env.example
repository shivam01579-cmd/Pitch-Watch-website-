# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Blogger Details
BLOG_ID=your_blogger_blog_id_here

# Google Sheets Database Details
# The ID is the long string in the sheet's URL: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
SPREADSHEET_ID=your_google_sheet_id_here

# Gemini API Key (Required for AI content generation)
# Get a FREE API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Free Stock Image API Keys (to fetch dynamic high-quality sports photos)
# If left blank, the script falls back to a curated list of high-quality cricket stock photos.
# Register for free at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
# Register for free at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here
