# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Blogger Details
BLOG_ID=your_blogger_blog_id_here

# Google Sheets Database Details
# The ID is the long string in the sheet's URL: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
SPREADSHEET_ID=your_google_sheet_id_here

# Gemini API Key (Required for AI content generation)
# Get a FREE API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Free Stock Image API Keys (to fetch dynamic high-quality sports photos)
# If left blank, the script falls back to a curated list of high-quality cricket stock photos.
# Register for free at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
# Register for free at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Optional: YouTube integration for auto-embedding your videos in posts
# Get your channel handle from YouTube (starts with @, e.g. @Cricbuzz)
YOUTUBE_HANDLE=your_youtube_handle_here

# Facebook Share Assistant configuration
# Your public Facebook Page URL (where you will publish organic posts)
FACEBOOK_PAGE_URL=https://www.facebook.com/your_page_here
# Comma-separated list of target Facebook groups to share captions and link-in-comments
FACEBOOK_GROUPS=https://www.facebook.com/groups/group_id_1,https://www.facebook.com/groups/group_id_2

# 100% Automated Telegram Channel Configuration
# Create a bot via @BotFather on Telegram to get your Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Add your Telegram Channel username (starts with @, e.g. @your_channel_username)
# Note: The Bot must be added as an Administrator to this channel!
TELEGRAM_CHANNEL_ID=your_channel_username_here

# 100% Automated Facebook Page Configuration (Meta Graph API)
# Find your Facebook Page ID in your Page's About Info
FACEBOOK_PAGE_ID=your_facebook_page_id_here
# Generate a Page Access Token via Meta for Developers dashboard
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here



